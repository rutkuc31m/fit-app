api.fit.rutkuc.com {
    reverse_proxy localhost:8001
    encode gzip
}

fit.rutkuc.com {
    root * /var/www/fitapp
    encode gzip
    try_files {path} /index.html

    # HTML + service worker + manifest must never be cached — so new deploys land immediately
    @nocache {
        path /index.html /sw.js /registerSW.js /manifest.webmanifest /workbox-*.js
    }
    header @nocache Cache-Control "no-store, must-revalidate"

    # Hashed immutable assets (vite emits /assets/*-HASH.{js,css})
    @immutable path /assets/*
    header @immutable Cache-Control "public, max-age=31536000, immutable"

    file_server
}
